{
  "kind": "backend",
  "tool": "IdTool",
  "cases": [
    {
      "name": "token length",
      "method": "generateToken",
      "args": [16],
      "matches": "^.{16}$"
    },
    {
      "name": "mac address format",
      "method": "generateMacAddress",
      "args": [],
      "matches": "^[0-9A-F]{2}(:[0-9A-F]{2}){5}$"
    },
    {
      "name": "port range",
      "method": "generatePort",
      "args": [],
      "matches": "^([1-9][0-9]{3,4}|1024|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$"
    }
  ]
}
